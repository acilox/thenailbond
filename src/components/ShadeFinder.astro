---
import { site } from '../data/site';

// Curated on-brand shades (soft, minimal, luxe) + a couple of statement options.
const shades = [
  { name: 'Ballet Slipper', hex: '#f0dcd7', note: 'the barely-there everyday blush' },
  { name: 'Almond Milk', hex: '#ece2d6', note: 'clean, milky and understated' },
  { name: 'Café au Lait', hex: '#cbb09a', note: 'warm nude that flatters every hand' },
  { name: 'Rosewood', hex: '#b5827d', note: 'muted rose — our signature' },
  { name: 'Mauve Mist', hex: '#c8a2ad', note: 'soft, dusty and romantic' },
  { name: 'Mocha', hex: '#8a6a5b', note: 'rich, cozy and grown-up' },
  { name: 'Classic Red', hex: '#b23b45', note: 'timeless, for when you mean it' },
];
const first = shades[0];

// 5 almond nails in a gentle arc (tip offsets create the fan).
const nails = [
  { x: 8, y: 34 },
  { x: 66, y: 14 },
  { x: 124, y: 4 },
  { x: 182, y: 14 },
  { x: 240, y: 34 },
];
---

<section id="shades" class="relative overflow-hidden py-20 sm:py-28" data-wa={site.waNumber}>
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <div class="reveal mx-auto max-w-2xl text-center">
      <span class="eyebrow">Play a little</span>
      <h2 class="display-2 mt-3">Find your shade.</h2>
      <p class="mt-4 text-lg text-[var(--color-taupe)]">
        Tap a colour to try it on. Not sure which is you? Send the one you love and
        I'll help you decide when you book.
      </p>
    </div>

    <div class="mt-12 grid items-center gap-10 lg:grid-cols-2">
      <!-- Interactive nails -->
      <div class="reveal reveal-scale order-1">
        <div class="relative mx-auto max-w-md rounded-[2rem] border border-[var(--color-mist)] bg-gradient-to-br from-white to-[var(--color-rose-tint)] p-8 shadow-[0_30px_60px_-36px_rgba(110,81,87,0.4)]">
          <svg id="nailSet" class="nail-set mx-auto w-full max-w-xs" viewBox="0 0 296 150" style={`--shade:${first.hex}`} role="img" aria-label="Nail shade preview">
            {
              nails.map((n) => (
                <g transform={`translate(${n.x} ${n.y})`}>
                  <path class="nail-plate" d="M5 94 C5 58 15 33 24 23 C33 33 43 58 43 94 C43 106 5 106 5 94 Z" />
                  <ellipse class="nail-gloss" cx="18" cy="40" rx="5.5" ry="17" transform="rotate(-12 18 40)" />
                </g>
              ))
            }
          </svg>
          <p class="mt-5 text-center">
            <span id="shadeName" class="block font-[var(--font-display)] text-xl font-semibold text-[var(--color-mauve)]">{first.name}</span>
            <span id="shadeNote" class="mt-1 block text-sm text-[var(--color-taupe)]">{first.note}</span>
          </p>
        </div>
      </div>

      <!-- Swatches + CTA -->
      <div class="reveal reveal-2 order-2">
        <p class="mb-4 text-sm font-semibold uppercase tracking-[0.14em] text-[var(--color-gold)]">The shade edit</p>
        <div id="swatches" class="flex flex-wrap gap-3">
          {
            shades.map((s, i) => (
              <button
                type="button"
                class="swatch"
                data-hex={s.hex}
                data-name={s.name}
                data-note={s.note}
                aria-pressed={i === 0 ? 'true' : 'false'}
                aria-label={`Try ${s.name}`}
                style={`background:${s.hex}`}
              />
            ))
          }
        </div>

        <div class="mt-8 rounded-2xl border border-[var(--color-mist)] bg-white p-5">
          <p class="text-[15px] text-[var(--color-taupe)]">
            Found the one? Book it in and I'll have your <span id="shadeInline" class="font-semibold text-[var(--color-mauve)]">{first.name}</span> ready for you.
          </p>
          <a
            id="shadeBook"
            href={site.waHref}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-whatsapp mt-4 w-full text-base sm:w-auto"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.9-4.45 9.9-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2z"/></svg>
            Book this shade
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
