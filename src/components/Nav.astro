---
import { site } from '../data/site';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const links = [
  { href: '#services', label: 'Services' },
  { href: '#gallery', label: 'Gallery' },
  { href: '#about', label: 'About' },
  { href: '#faq', label: 'FAQ' },
];
---

<header id="siteNav" class="fixed inset-x-0 top-0 z-50">
  <nav class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-5 py-3.5 sm:px-8">
    <!-- Brand -->
    <a href="#top" class="flex items-center gap-2.5" aria-label={site.fullName}>
      <img src={`${base}/favicon.svg`} width="40" height="40" alt="" class="rounded-xl" />
      <span class="hidden leading-tight sm:block">
        <span class="block font-[var(--font-display)] text-[1.05rem] font-semibold text-[var(--color-mauve)]"
          >The Nail Bond</span
        >
        <span class="block text-[0.64rem] font-semibold uppercase tracking-[0.18em] text-[var(--color-taupe)]"
          >by Mel · Serena, Dubai</span
        >
      </span>
    </a>

    <!-- Desktop links -->
    <ul class="hidden items-center gap-7 lg:flex">
      {
        links.map((l) => (
          <li>
            <a
              href={l.href}
              class="text-sm font-medium text-[var(--color-taupe)] transition-colors hover:text-[var(--color-rose)]"
            >
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Contact + CTA -->
    <div class="flex items-center gap-3">
      <a
        href={site.socials.instagram}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Instagram"
        class="hidden text-[var(--color-mauve)] transition-colors hover:text-[var(--color-rose)] md:block"
      >
        <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
      </a>
      <a href={site.waHref} target="_blank" rel="noopener noreferrer" data-magnetic class="btn btn-primary !px-4 !py-2.5 text-sm">
        Book now
      </a>

      <button
        id="navToggle"
        class="lg:hidden"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobileMenu"
      >
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--color-mauve)" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobileMenu" class="hidden border-t border-[var(--color-mist)] bg-[var(--color-paper)]/95 backdrop-blur lg:hidden">
    <ul class="mx-auto flex max-w-7xl flex-col gap-1 px-5 py-4">
      {
        links.map((l) => (
          <li>
            <a href={l.href} class="block rounded-lg px-3 py-2.5 font-medium text-[var(--color-mauve)] hover:bg-[var(--color-mist)]">
              {l.label}
            </a>
          </li>
        ))
      }
      <li class="mt-1 flex gap-2 px-1">
        <a href={site.socials.igDm} target="_blank" rel="noopener noreferrer" class="btn btn-outline flex-1 !py-2.5 text-sm">Instagram DM</a>
        <a href={site.waHref} target="_blank" rel="noopener noreferrer" class="btn btn-primary flex-1 !py-2.5 text-sm">Book on WhatsApp</a>
      </li>
    </ul>
  </div>
</header>
