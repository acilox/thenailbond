---
import { site } from '../data/site';
---

<section id="book" class="px-5 py-20 sm:py-28">
  <div class="mx-auto max-w-6xl">
    <div class="bg-mauve relative overflow-hidden rounded-[2.5rem] px-6 py-16 text-center text-white sm:py-20">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_0%,rgba(255,255,255,0.14),transparent_55%)]" aria-hidden="true"></div>

      <div class="relative mx-auto max-w-2xl">
        <span class="eyebrow !text-[var(--color-gold-bright)]">Ready when you are</span>
        <h2 class="mt-4 !text-white" style="font-family:var(--font-display); font-weight:550; font-size:clamp(2rem,5vw,3.25rem); line-height:1.05;">
          Let's book your nails in.
        </h2>
        <p class="mt-5 text-lg text-white/85">
          Message on WhatsApp or Instagram and tell me what you'd love — I'll help you
          choose and find a time that suits you. Cozy home studio in Serena, Dubai.
        </p>

        <div class="mt-9 flex flex-wrap justify-center gap-3">
          <a href={site.waHref} target="_blank" rel="noopener noreferrer" data-magnetic class="btn btn-whatsapp text-base">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.9-4.45 9.9-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2zm0 18.15h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.2 8.2 0 0 1-1.26-4.38c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.69 8.23-8.24 8.23zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.02-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.4-.42-.56-.43h-.48c-.17 0-.43.06-.66.31-.22.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29z"/></svg>
            Book on WhatsApp
          </a>
          <a href={site.socials.igDm} target="_blank" rel="noopener noreferrer" class="btn btn-ghost-light text-base">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
            DM on Instagram
          </a>
        </div>

        <p class="mt-8 text-sm text-white/70">
          {site.hours} · Home studio address shared on booking
        </p>
      </div>
    </div>
  </div>
</section>
