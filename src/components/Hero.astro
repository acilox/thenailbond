---
import { Image } from 'astro:assets';
import { site } from '../data/site';
import heroNails from '../assets/hero-nails.jpg';
import heroAngle2 from '../assets/hero-angle-2.jpg';
import heroAngle3 from '../assets/hero-angle-3.jpg';
---

<section id="top" class="bg-hero-soft relative overflow-hidden pt-24 pb-14 sm:pt-40 sm:pb-28">
  <!-- Decorative sparkles -->
  <svg class="sparkle" style="top:18%;left:8%;width:22px;height:22px;animation-delay:0s" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0l2.4 8.6L23 12l-8.6 2.4L12 23l-2.4-8.6L1 12l8.6-2.4z"/></svg>
  <svg class="sparkle" style="top:60%;left:44%;width:14px;height:14px;animation-delay:1.2s" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0l2.4 8.6L23 12l-8.6 2.4L12 23l-2.4-8.6L1 12l8.6-2.4z"/></svg>
  <svg class="sparkle" style="top:30%;right:46%;width:16px;height:16px;animation-delay:2.1s" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0l2.4 8.6L23 12l-8.6 2.4L12 23l-2.4-8.6L1 12l8.6-2.4z"/></svg>

  <div class="mx-auto grid max-w-7xl grid-cols-1 gap-7 px-5 sm:gap-8 sm:px-8 lg:grid-cols-[1.02fr_0.98fr] lg:gap-14">
    <!-- (A) Chip + headline — first on mobile, top-left on desktop -->
    <div class="relative z-10 text-center lg:col-start-1 lg:row-start-1 lg:self-end lg:text-left">
      <span class="chip reveal mb-5">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 11-8 11s-8-5-8-11a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="2.5"/></svg>
        Home studio · Serena, Dubai
      </span>

      <h1 class="display-1">
        <span class="kinetic-line"><span>Luxury nails,</span></span>
        <span class="kinetic-line kinetic-line--swoosh">
          <span class="relative inline-block">
            <span class="text-gradient">cozy studio.</span>
            <!-- hand-drawn swoosh -->
            <svg class="swoosh absolute -bottom-1 left-0 w-full" height="20" viewBox="0 0 300 20" fill="none" aria-hidden="true" preserveAspectRatio="none">
              <path d="M4 13C60 5 150 3 296 9" stroke="var(--color-gold-bright)" stroke-width="4" stroke-linecap="round"/>
            </svg>
          </span>
        </span>
      </h1>
    </div>

    <!-- (B) Visual — 3-angle swipe carousel on mobile, layered collage on desktop -->
    <div class="reveal reveal-3 reveal-scale relative mx-auto w-full max-w-md lg:col-start-2 lg:row-start-1 lg:row-span-2 lg:my-4 lg:max-w-none lg:self-center">
      <div class="float relative">
        <div class="absolute -inset-4 -z-10 hidden rounded-[2.5rem] bg-gradient-to-br from-[var(--color-rose-soft)] to-[var(--color-gold-soft)] opacity-70 blur-2xl lg:block"></div>

        <div class="hero-stage no-scrollbar" aria-label="A few angles of recent work">
          <!-- Main — signature soft/nude set (LCP image) -->
          <div class="hero-tile hero-tile--main">
            <div class="img-frame aspect-[4/5]">
              <!-- ⚠️ Placeholder (AI-generated). Swap for Melanie's own hero photo. -->
              <Image
                src={heroNails}
                alt="Soft, natural nude manicure — the signature look at The Nail Bond"
                widths={[400, 700, 1000]}
                sizes="(max-width: 1024px) 80vw, 460px"
                loading="eager"
                fetchpriority="high"
              />
            </div>
          </div>

          <!-- Angle 2 — glossy macro detail -->
          <div class="hero-tile hero-tile--a">
            <div class="img-frame aspect-square">
              <Image
                src={heroAngle2}
                alt="Close-up of a glossy nude gel finish"
                widths={[260, 420]}
                sizes="(max-width: 1024px) 78vw, 220px"
                loading="eager"
              />
            </div>
          </div>

          <!-- Angle 3 — hand at rest with delicate art -->
          <div class="hero-tile hero-tile--b">
            <div class="img-frame aspect-[4/3]">
              <Image
                src={heroAngle3}
                alt="A hand at rest showing a soft-pink manicure with a tiny gold accent"
                widths={[260, 440]}
                sizes="(max-width: 1024px) 78vw, 200px"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      </div>

      <!-- Rotating sticker badge -->
      <div class="pointer-events-none absolute right-1 top-1 z-30 h-20 w-20 sm:-right-3 sm:-top-3 sm:h-28 sm:w-28">
        <svg class="spin-slow h-full w-full" viewBox="0 0 100 100" aria-hidden="true">
          <defs>
            <path id="badgeCircle" d="M50,50 m-34,0 a34,34 0 1,1 68,0 a34,34 0 1,1 -68,0" />
          </defs>
          <circle cx="50" cy="50" r="46" fill="var(--color-mauve)" />
          <text fill="var(--color-gold-soft)" font-size="9.5" font-family="var(--font-sans)" font-weight="600" letter-spacing="2.4">
            <textPath href="#badgeCircle" startOffset="0%">· BOOK NOW · DM TO RESERVE </textPath>
          </text>
        </svg>
        <svg class="absolute inset-0 m-auto h-7 w-7 sm:h-8 sm:w-8" style="top:0;bottom:0;left:0;right:0" viewBox="0 0 24 24" fill="var(--color-gold-bright)"><path d="M12 0l2.4 8.6L23 12l-8.6 2.4L12 23l-2.4-8.6L1 12l8.6-2.4z"/></svg>
      </div>
    </div>

    <!-- (C) Subcopy + CTAs + trust — after the visual on mobile, bottom-left on desktop -->
    <div class="relative z-10 text-center lg:col-start-1 lg:row-start-2 lg:self-start lg:text-left">
      <p class="measure reveal reveal-3 mx-auto text-lg leading-relaxed text-[var(--color-taupe)] lg:mx-0">
        Soft, clean, minimal nails — thoughtfully done, one client at a time, in a
        calm little home studio in Serena. <span class="hidden sm:inline">BIAB, Russian manicure, extensions and
        delicate art that quietly elevate your everyday look.</span>
      </p>

      <div class="reveal reveal-4 mt-7 flex flex-wrap items-center justify-center gap-3 lg:justify-start">
        <a href={site.waHref} target="_blank" rel="noopener noreferrer" data-magnetic class="btn btn-whatsapp text-base">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.9-4.45 9.9-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2zm0 18.15h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.2 8.2 0 0 1-1.26-4.38c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.69 8.23-8.24 8.23zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.02-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.4-.42-.56-.43h-.48c-.17 0-.43.06-.66.31-.22.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29z"/></svg>
          Book on WhatsApp
        </a>
        <a href={site.socials.igDm} target="_blank" rel="noopener noreferrer" class="btn btn-outline text-base">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          DM on Instagram
        </a>
      </div>

      <!-- Trust row -->
      <ul class="reveal reveal-5 mx-auto mt-9 grid max-w-lg grid-cols-3 gap-4 border-t border-[var(--color-mist)] pt-7 sm:gap-6 lg:mx-0">
        <li>
          <p class="font-[var(--font-display)] text-xl font-semibold text-[var(--color-mauve)] sm:text-2xl">1-on-1</p>
          <p class="mt-1 text-xs text-[var(--color-taupe)] sm:text-sm">never rushed, just you</p>
        </li>
        <li>
          <p class="font-[var(--font-display)] text-xl font-semibold text-[var(--color-mauve)] sm:text-2xl">Hygienic</p>
          <p class="mt-1 text-xs text-[var(--color-taupe)] sm:text-sm">sterilised tools, every time</p>
        </li>
        <li>
          <p class="font-[var(--font-display)] text-xl font-semibold text-[var(--color-mauve)] sm:text-2xl">By appt.</p>
          <p class="mt-1 text-xs text-[var(--color-taupe)] sm:text-sm">flexible, cozy home studio</p>
        </li>
      </ul>
    </div>
  </div>
</section>
