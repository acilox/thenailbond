---
import { Image } from 'astro:assets';
import { site } from '../data/site';
import heroNails from '../assets/hero-nails.jpg';
---

<section id="top" class="bg-hero-soft relative overflow-hidden pt-32 pb-20 sm:pt-40 sm:pb-28">
  <div class="mx-auto grid max-w-7xl items-center gap-14 px-5 sm:px-8 lg:grid-cols-[1.02fr_0.98fr]">
    <!-- Copy -->
    <div class="reveal">
      <span class="chip mb-5">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 11-8 11s-8-5-8-11a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="2.5"/></svg>
        Home studio · Serena, Dubai
      </span>

      <h1 class="display-1">
        Luxury nails,<br />
        <span class="text-gradient">cozy studio.</span>
      </h1>

      <p class="measure mt-6 text-lg leading-relaxed text-[var(--color-taupe)]">
        Soft, clean, minimal nails — thoughtfully done, one client at a time, in a
        calm little home studio in Serena. BIAB, Russian manicure, extensions and
        delicate art that quietly elevate your everyday look.
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a href={site.waHref} target="_blank" rel="noopener noreferrer" data-magnetic class="btn btn-whatsapp text-base">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.9-4.45 9.9-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2zm0 18.15h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.2 8.2 0 0 1-1.26-4.38c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.69 8.23-8.24 8.23zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.02-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.4-.42-.56-.43h-.48c-.17 0-.43.06-.66.31-.22.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29z"/></svg>
          Book on WhatsApp
        </a>
        <a href={site.socials.igDm} target="_blank" rel="noopener noreferrer" class="btn btn-outline text-base">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          DM on Instagram
        </a>
      </div>

      <!-- Trust row -->
      <ul class="mt-11 grid max-w-lg grid-cols-3 gap-6 border-t border-[var(--color-mist)] pt-7">
        <li>
          <p class="font-[var(--font-display)] text-2xl font-semibold text-[var(--color-mauve)]">1-on-1</p>
          <p class="mt-1 text-sm text-[var(--color-taupe)]">never rushed, just you</p>
        </li>
        <li>
          <p class="font-[var(--font-display)] text-2xl font-semibold text-[var(--color-mauve)]">Hygienic</p>
          <p class="mt-1 text-sm text-[var(--color-taupe)]">sterilised tools, every time</p>
        </li>
        <li>
          <p class="font-[var(--font-display)] text-2xl font-semibold text-[var(--color-mauve)]">By appt.</p>
          <p class="mt-1 text-sm text-[var(--color-taupe)]">flexible, cozy home studio</p>
        </li>
      </ul>
    </div>

    <!-- Visual -->
    <div class="reveal reveal-2 relative">
      <div class="absolute -inset-4 -z-10 rounded-[2.25rem] bg-gradient-to-br from-[var(--color-rose-soft)] to-[var(--color-gold-soft)] opacity-70 blur-2xl"></div>
      <div class="card overflow-hidden shadow-[0_40px_80px_-40px_rgba(110,81,87,0.4)]">
        <!-- ⚠️ Placeholder (licensed Unsplash). Swap for Melanie's own hero photo. -->
        <Image
          src={heroNails}
          alt="Soft, natural pink manicure — the signature look at The Nail Bond"
          widths={[400, 700, 1000]}
          sizes="(max-width: 1024px) 90vw, 520px"
          loading="eager"
          fetchpriority="high"
          class="aspect-[4/5] w-full object-cover"
        />
      </div>
      <!-- Floating rating badge -->
      <div class="card absolute -bottom-5 -left-2 flex items-center gap-3 p-3.5 shadow-xl sm:-left-6">
        <span class="icon-badge !h-10 !w-10 !rounded-lg !bg-[var(--color-gold-soft)] !text-[var(--color-gold)] !border-[var(--color-gold-soft)]">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.9 6.26 6.6.53-5.02 4.3 1.53 6.41L12 16.9l-6.01 3.11 1.53-6.41L2.5 8.79l6.6-.53z"/></svg>
        </span>
        <div>
          <p class="text-sm font-semibold text-[var(--color-mauve)]">Loved by clients</p>
          <p class="text-xs text-[var(--color-taupe)]">soft, clean & long-lasting</p>
        </div>
      </div>
    </div>
  </div>
</section>
