---
import { site } from '../data/site';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const links = [
  { href: '#services', label: 'Services' },
  { href: '#gallery', label: 'Gallery' },
  { href: '#about', label: 'About Mel' },
  { href: '#faq', label: 'FAQ' },
];
---

<footer class="border-t border-[var(--color-mist)] bg-[var(--color-nude-soft)]/40">
  <div class="mx-auto grid max-w-7xl gap-10 px-5 py-14 sm:px-8 md:grid-cols-3">
    <!-- Brand + NAP -->
    <div>
      <a href="#top" class="flex items-center gap-2.5" aria-label={site.fullName}>
        <img src={`${base}/favicon.svg`} width="40" height="40" alt="" class="rounded-xl" />
        <span class="leading-tight">
          <span class="block font-[var(--font-display)] text-lg font-semibold text-[var(--color-mauve)]">The Nail Bond</span>
          <span class="block text-[0.66rem] font-semibold uppercase tracking-[0.16em] text-[var(--color-taupe)]">by Mel</span>
        </span>
      </a>
      <p class="mt-4 max-w-xs text-sm leading-relaxed text-[var(--color-taupe)]">
        {site.tagline} Soft, clean, minimal nails from a cozy home studio in
        {' '}{site.area}.
      </p>
    </div>

    <!-- Explore -->
    <div>
      <h4 class="mb-3 text-sm font-semibold text-[var(--color-mauve)]">Explore</h4>
      <ul class="space-y-2 text-sm text-[var(--color-taupe)]">
        {links.map((l) => (
          <li><a href={l.href} class="transition-colors hover:text-[var(--color-rose)]">{l.label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Book / contact -->
    <div>
      <h4 class="mb-3 text-sm font-semibold text-[var(--color-mauve)]">Book & follow</h4>
      <ul class="space-y-2 text-sm text-[var(--color-taupe)]">
        <li><a href={site.waHref} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-[var(--color-rose)]">Book on WhatsApp →</a></li>
        <li><a href={site.socials.instagram} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-[var(--color-rose)]">@{site.instagramHandle} on Instagram</a></li>
        <li class="text-[var(--color-taupe)]">{site.hours}</li>
        <li class="text-[var(--color-taupe)]">Home studio · address shared on booking</li>
      </ul>
      <div class="mt-4 flex gap-3">
        <a href={site.socials.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="grid h-9 w-9 place-items-center rounded-lg border border-[var(--color-mist)] bg-white text-[var(--color-mauve)] transition-colors hover:border-[var(--color-rose)] hover:text-[var(--color-rose)]">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
        </a>
        <a href={site.waHref} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="grid h-9 w-9 place-items-center rounded-lg border border-[var(--color-mist)] bg-white text-[#25d366] transition-colors hover:border-[#25d366]">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.9-4.45 9.9-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2z"/></svg>
        </a>
      </div>
    </div>
  </div>

  <div class="border-t border-[var(--color-mist)]">
    <div class="mx-auto flex max-w-7xl flex-col justify-between gap-2 px-5 py-5 text-xs text-[var(--color-taupe)] sm:flex-row sm:px-8">
      <p>© {new Date().getFullYear()} {site.fullName}. All rights reserved.</p>
      <p>Nails done with passion &amp; precision in Dubai. 💅</p>
    </div>
  </div>
</footer>
