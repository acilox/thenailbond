---
import { Image } from 'astro:assets';
import { site } from '../data/site';
import studio from '../assets/studio.jpg';

const notes = [
  'Home studio in Serena, Dubai',
  'BIAB · Russian mani · extensions',
  'Soft, clean, minimal signature look',
  'Dog mom to Peachy 🐶',
];
---

<section id="about" class="py-20 sm:py-28">
  <div class="mx-auto grid max-w-7xl items-center gap-12 px-5 sm:px-8 lg:grid-cols-[0.9fr_1.1fr]">
    <!-- Portrait -->
    <div class="reveal">
      <div class="relative mx-auto max-w-sm">
        <div class="absolute -inset-3 -z-10 rounded-[1.75rem] bg-gradient-to-br from-[var(--color-rose-soft)] to-[var(--color-gold-soft)] blur-xl"></div>
        <!-- ⚠️ Placeholder (AI-generated). Swap for a real photo of Melanie / her studio. -->
        <Image
          src={studio}
          alt="Melanie's cozy home nail studio in Serena, Dubai"
          widths={[360, 560, 760]}
          sizes="(max-width: 1024px) 90vw, 400px"
          loading="lazy"
          class="aspect-[4/5] w-full rounded-[1.5rem] border border-[var(--color-mist)] object-cover shadow-[0_30px_60px_-36px_rgba(110,81,87,0.45)]"
        />
        <div class="card absolute -bottom-5 -right-2 flex items-center gap-3 p-3.5 shadow-xl sm:-right-6">
          <span class="icon-badge !h-10 !w-10 !rounded-lg">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 11-8 11s-8-5-8-11a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="2.5"/></svg>
          </span>
          <div>
            <p class="text-sm font-semibold text-[var(--color-mauve)]">Serena, Dubai</p>
            <p class="text-xs text-[var(--color-taupe)]">cozy · private · by appointment</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Bio -->
    <div class="reveal reveal-2">
      <span class="eyebrow">Meet your nail artist</span>
      <h2 class="display-2 mt-3">Hi, I'm Melanie.</h2>

      <div class="measure mt-6 space-y-4 text-[17px] leading-relaxed text-[var(--color-ink)]">
        <p>
          I'm a nail tech based in Dubai, working from my cozy home studio in Serena —
          creating soft, clean, minimal nails with BIAB, Russian manicure and
          extensions.
        </p>
        <p>
          My focus is simple: <em>less is more.</em> Clean details, healthy natural
          nails, and a finish that quietly elevates your everyday look — never loud,
          always considered.
        </p>
        <p>
          Outside the studio, I'm a dog mom to Peachy, a hopeless food lover, and
          someone who enjoys slow, simple living in Dubai. My little space is where
          you get unhurried, one-on-one time — just you, a good chat, and beautiful
          nails to leave with.
        </p>
      </div>

      <ul class="mt-7 grid gap-3 sm:grid-cols-2">
        {
          notes.map((c) => (
            <li class="flex items-start gap-2.5 text-[15px] text-[var(--color-ink)]">
              <svg class="mt-0.5 shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-rose)" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              {c}
            </li>
          ))
        }
      </ul>

      <div class="mt-8 flex flex-wrap gap-3">
        <a href={site.waHref} target="_blank" rel="noopener noreferrer" class="btn btn-primary text-sm">Book with Mel</a>
        <a href={site.socials.instagram} target="_blank" rel="noopener noreferrer" class="btn btn-outline text-sm">See my work</a>
      </div>
    </div>
  </div>
</section>
