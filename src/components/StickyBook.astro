---
// Mobile-only sticky booking bar — keeps the primary WhatsApp CTA one tap away
// on phones (playbook §7: sticky mobile CTA). Reveals after the hero scrolls past
// and hides near the footer so it never covers the final CTA. Toggled in BaseLayout.
import { site } from '../data/site';
---

<div id="stickyBook" class="fixed inset-x-0 bottom-0 z-40 lg:hidden">
  <div class="m-3 flex items-center gap-2 rounded-2xl border border-[var(--color-mist)] bg-[var(--color-paper)]/95 p-2 shadow-[0_-10px_30px_-12px_rgba(110,81,87,0.45)] backdrop-blur">
    <a href={site.waHref} target="_blank" rel="noopener noreferrer" class="btn btn-whatsapp flex-1 !py-3 text-sm">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.9-4.45 9.9-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2zm0 18.15h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.2 8.2 0 0 1-1.26-4.38c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.69 8.23-8.24 8.23zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.02-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.4-.42-.56-.43h-.48c-.17 0-.43.06-.66.31-.22.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29z"/></svg>
      Book on WhatsApp
    </a>
    <a href={site.socials.igDm} target="_blank" rel="noopener noreferrer" aria-label="Message on Instagram" class="btn btn-outline !px-4 !py-3">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
    </a>
  </div>
</div>
